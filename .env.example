GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=your_openai_api_key_here  # Optional: use GPT-4o instead of DeepSeek
OLLAMA_URL=http://localhost:11434  # Self-hosted Ollama server (OpenAI-compatible endpoint)
OLLAMA_MODEL=llama3.2  # e.g. llama3.2, mistral, qwen2.5, gemma3
AI_PROVIDER=deepseek  # "openai", "deepseek", or "ollama"
MODEL=deepseek-chat  # deepseek-chat (latest), deepseek-reasoner, gpt-4o, etc.
SIDECAR_PORT=3001
